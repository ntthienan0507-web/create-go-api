# Server
SERVER_PORT={{.ServerPort}}
SERVER_MODE=debug     # debug | release

# Database
DB_DRIVER={{if .IncludeSQLC}}sqlc{{else}}gorm{{end}}        # {{if and .IncludeSQLC .IncludeGORM}}sqlc | gorm{{else if .IncludeSQLC}}sqlc{{else}}gorm{{end}}
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME={{.DBName}}
DB_SSL_MODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# Auth - select provider
AUTH_PROVIDER={{if .IncludeJWT}}jwt{{else}}keycloak{{end}}     # {{if and .IncludeJWT .IncludeKeycloak}}jwt | keycloak{{else if .IncludeJWT}}jwt{{else}}keycloak{{end}}
{{- if .IncludeJWT}}

# JWT (only when AUTH_PROVIDER=jwt)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY=24h
{{- end}}
{{- if .IncludeKeycloak}}

# Keycloak (only when AUTH_PROVIDER=keycloak)
KEYCLOAK_HOST=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
{{- end}}

# Logging
LOG_LEVEL=debug       # debug | info | warn | error
LOG_FORMAT=console    # console | json
